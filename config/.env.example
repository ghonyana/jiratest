# Flask Configuration
FLASK_APP=src.app:create_app
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# MongoDB Configuration (Optional)
ENABLE_MONGO=false
MONGODB_URI=mongodb://localhost:27017/jiratest-dev

# Jira Configuration
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_PROJECT_KEY=ET
JIRA_API_TOKEN=your-jira-api-token
JIRA_API_USER=your-email@example.com

# Webhook Authentication
VERCEL_WEBHOOK_SECRET=your-vercel-webhook-secret
GCP_AUDIENCE=https://error-triage.jiratest.com/events

# AWS Configuration
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_ENABLED=false

# Application Configuration
COMMENT_RATE_LIMIT_MINUTES=15
EVENT_DEDUP_TTL_SECONDS=3600
FREQUENCY_WINDOW_SECONDS=300

# Logging
LOG_LEVEL=INFO

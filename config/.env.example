# ============================================================================
# Error Triage → Jira Upserter Service - Environment Configuration Template
# ============================================================================
#
# SECURITY WARNING: This is a template file with example values only.
# NEVER commit the actual .env file to version control!
# Real credentials must be stored in AWS Secrets Manager or loaded securely.
#
# Usage:
#   1. Copy this file to .env in the project root
#   2. Replace all example values with actual configuration
#   3. Ensure .env is listed in .gitignore
#   4. For production, use AWS Secrets Manager and load via boto3
#
# ============================================================================

# ----------------------------------------------------------------------------
# Flask Application Configuration
# ----------------------------------------------------------------------------

# Flask environment mode
# Values: development | staging | production
# Default: production
# Required: Yes
FLASK_ENV=production

# Flask application entry point
# Format: module:function
# Default: src.app:create_app
# Required: Yes
FLASK_APP=src.app:create_app

# Flask secret key for session management and CSRF protection
# Format: Random string (min 32 characters)
# Generation: python -c "import secrets; print(secrets.token_hex(32))"
# Required: Yes
SECRET_KEY=your-secret-key-here-minimum-32-characters-long

# Application logging level
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
# Required: No
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# AWS Infrastructure Configuration
# ----------------------------------------------------------------------------

# AWS region for all resources
# Format: AWS region code (e.g., us-east-1, us-west-2)
# Default: us-east-1
# Required: Yes
AWS_REGION=us-east-1

# Prefix for AWS Secrets Manager secret names
# Format: Path-like string without trailing slash
# Example: jira/jiratest/{environment}/credentials
# Default: jira/jiratest
# Required: No
AWS_SECRETS_MANAGER_PREFIX=jira/jiratest

# AWS credentials (if not using IAM role)
# Note: In production, use IAM roles for ECS tasks instead
# Required: Only if not using IAM role
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ----------------------------------------------------------------------------
# Redis Configuration
# ----------------------------------------------------------------------------

# Redis server hostname or IP address
# Format: Hostname or IP (ElastiCache endpoint in production)
# Example: jiratest-error-triage-redis-prod.abc123.cache.amazonaws.com
# Required: Yes
REDIS_HOST=localhost

# Redis server port
# Format: Integer (1-65535)
# Default: 6379
# Required: No
REDIS_PORT=6379

# Redis database number
# Format: Integer (0-15)
# Default: 0
# Required: No
REDIS_DB=0

# Redis authentication password
# Format: String (empty if no auth required)
# Note: Load from AWS Secrets Manager in production
# Default: (empty)
# Required: Only if Redis requires authentication
REDIS_PASSWORD=

# Redis SSL/TLS connection
# Values: true | false
# Default: false (true for ElastiCache in production)
# Required: No
REDIS_SSL=false

# Redis connection timeout in seconds
# Format: Integer (1-60)
# Default: 5
# Required: No
REDIS_CONNECT_TIMEOUT=5

# Redis socket timeout in seconds
# Format: Integer (1-60)
# Default: 5
# Required: No
REDIS_SOCKET_TIMEOUT=5

# ----------------------------------------------------------------------------
# MongoDB Configuration (Optional - Audit Logs Only)
# ----------------------------------------------------------------------------

# Enable MongoDB audit logging
# Values: true | false
# Default: false
# Note: MongoDB is optional and only used for append-only audit trail
# Required: No
ENABLE_MONGO=false

# MongoDB connection URI
# Format: mongodb://[username:password@]host[:port]/[database][?options]
# Example: mongodb+srv://user:pass@cluster.mongodb.net/jiratest-prod?retryWrites=true
# Note: Load from AWS Secrets Manager in production
# Required: Only if ENABLE_MONGO=true
MONGODB_URI=mongodb://localhost:27017/jiratest-dev

# MongoDB database name
# Format: Alphanumeric string with hyphens
# Default: jiratest-{environment}
# Required: Only if ENABLE_MONGO=true
MONGODB_DATABASE=jiratest-dev

# MongoDB connection timeout in milliseconds
# Format: Integer (1000-30000)
# Default: 5000
# Required: No
MONGODB_CONNECT_TIMEOUT=5000

# ----------------------------------------------------------------------------
# Jira Integration Configuration
# ----------------------------------------------------------------------------

# Jira Cloud instance base URL
# Format: https://{organization}.atlassian.net (no trailing slash)
# Example: https://mycompany.atlassian.net
# Note: Load from AWS Secrets Manager in production
# Required: Yes
JIRA_BASE_URL=https://your-org.atlassian.net

# Jira API authentication email
# Format: Email address associated with API token
# Example: api-user@example.com
# Note: Load from AWS Secrets Manager in production
# Required: Yes
JIRA_API_EMAIL=api-user@example.com

# Jira API authentication token
# Format: Alphanumeric token from Atlassian account settings
# Generation: https://id.atlassian.com/manage-profile/security/api-tokens
# Note: Load from AWS Secrets Manager in production
# Required: Yes
JIRA_API_TOKEN=your-jira-api-token-here

# Jira project key for error triage issues
# Format: Uppercase alphanumeric (typically 2-10 characters)
# Example: ET (Error Triage), BUG, ERRORS
# Required: Yes
JIRA_PROJECT_KEY=ET

# Jira custom field ID for severity classification
# Format: customfield_{number}
# Example: customfield_10050
# Note: Find via Jira API or admin interface
# Required: Yes (if using severity classification)
JIRA_CUSTOM_FIELD_SEVERITY=customfield_10050

# Jira API request timeout in seconds
# Format: Integer (5-30)
# Default: 10
# Required: No
JIRA_API_TIMEOUT=10

# Jira API rate limit (requests per minute)
# Format: Integer (10-100)
# Default: 100 (Jira Cloud default)
# Required: No
JIRA_RATE_LIMIT=100

# ----------------------------------------------------------------------------
# Webhook Authentication Configuration
# ----------------------------------------------------------------------------

# Vercel webhook signature secret
# Format: String (shared secret from Vercel Log Drain configuration)
# Generation: Configured in Vercel dashboard when creating Log Drain
# Note: Load from AWS Secrets Manager in production
# Required: Yes (if accepting Vercel webhooks)
VERCEL_WEBHOOK_SECRET=your-vercel-webhook-secret-here

# GCP Pub/Sub OIDC token audience
# Format: Service endpoint URL (must match push subscription audience)
# Example: https://error-triage.jiratest.com/events
# Note: Must match the URL configured in GCP push subscription
# Required: Yes (if accepting GCP Pub/Sub webhooks)
GCP_OIDC_AUDIENCE=https://error-triage.jiratest.com/events

# GCP project ID for log link construction
# Format: GCP project identifier (lowercase with hyphens)
# Example: my-gcp-project-123
# Required: Yes (if accepting GCP webhooks)
GCP_PROJECT_ID=your-gcp-project-id

# Webhook request timeout in seconds
# Format: Integer (5-30)
# Default: 10
# Required: No
WEBHOOK_TIMEOUT=10

# ----------------------------------------------------------------------------
# Operational Parameters Configuration
# ----------------------------------------------------------------------------

# Comment rate limit duration in minutes
# Format: Integer (1-60)
# Default: 15
# Note: Minimum time between comments on same issue (unless severity escalates)
# Required: No
COMMENT_RATE_LIMIT_MINUTES=15

# Event deduplication TTL in seconds
# Format: Integer (300-7200)
# Default: 3600 (1 hour)
# Note: How long to track processed event IDs to prevent duplicates
# Required: No
EVENT_DEDUP_TTL_SECONDS=3600

# Frequency counter TTL in seconds
# Format: Integer (60-900)
# Default: 300 (5 minutes)
# Note: Rolling window for error occurrence counting
# Required: No
FREQUENCY_COUNTER_TTL_SECONDS=300

# Maximum number of worker threads/processes
# Format: Integer (1-16)
# Default: 4
# Note: Gunicorn workers for handling concurrent requests
# Required: No
MAX_WORKERS=4

# Background worker retry attempts
# Format: Integer (1-10)
# Default: 5
# Note: Maximum attempts for failed Jira API calls before moving to DLQ
# Required: No
MAX_RETRY_ATTEMPTS=5

# Background worker backoff base in seconds
# Format: Float (0.5-5.0)
# Default: 1.0
# Note: Exponential backoff base: delay = base * (2 ^ attempt)
# Required: No
RETRY_BACKOFF_BASE=1.0

# SQS queue URL for async processing
# Format: https://sqs.{region}.amazonaws.com/{account}/{queue-name}
# Example: https://sqs.us-east-1.amazonaws.com/123456789012/jiratest-error-events-prod
# Note: Leave empty to use synchronous processing (not recommended for prod)
# Required: No (but recommended for production)
SQS_QUEUE_URL=

# Dead letter queue URL for failed events
# Format: https://sqs.{region}.amazonaws.com/{account}/{dlq-name}
# Example: https://sqs.us-east-1.amazonaws.com/123456789012/jiratest-error-events-dlq-prod
# Required: No (but recommended if using SQS)
SQS_DLQ_URL=

# ----------------------------------------------------------------------------
# Service Endpoints Configuration
# ----------------------------------------------------------------------------

# Service HTTP port
# Format: Integer (1024-65535)
# Default: 8080
# Required: No
SERVICE_PORT=8080

# Service bind host
# Format: IP address or hostname
# Default: 0.0.0.0 (all interfaces)
# Required: No
SERVICE_HOST=0.0.0.0

# Service external URL (for webhook callbacks)
# Format: https://{domain}[:{port}] (no trailing slash)
# Example: https://error-triage.jiratest.com
# Required: Yes (for GCP OIDC validation and log links)
SERVICE_EXTERNAL_URL=https://error-triage.jiratest.com

# Health check endpoint path
# Format: URL path starting with /
# Default: /healthz
# Required: No
HEALTH_CHECK_PATH=/healthz

# Metrics endpoint path
# Format: URL path starting with /
# Default: /metrics
# Required: No
METRICS_PATH=/metrics

# ----------------------------------------------------------------------------
# Configuration File Paths
# ----------------------------------------------------------------------------

# Severity rules YAML file path
# Format: Relative or absolute file path
# Default: config/severity_rules.yaml
# Required: No
SEVERITY_RULES_PATH=config/severity_rules.yaml

# Ownership rules YAML file path
# Format: Relative or absolute file path
# Default: config/ownership_rules.yaml
# Required: No
OWNERSHIP_RULES_PATH=config/ownership_rules.yaml

# Sanitization patterns YAML file path
# Format: Relative or absolute file path
# Default: config/sanitization_patterns.yaml
# Required: No
SANITIZATION_PATTERNS_PATH=config/sanitization_patterns.yaml

# ----------------------------------------------------------------------------
# Development and Testing Configuration
# ----------------------------------------------------------------------------

# Enable debug mode (verbose logging, auto-reload)
# Values: true | false
# Default: false
# Warning: NEVER enable in production
# Required: No
DEBUG=false

# Enable Flask debug toolbar
# Values: true | false
# Default: false
# Warning: Only for local development
# Required: No
FLASK_DEBUG_TOOLBAR=false

# Mock external services for testing
# Values: true | false
# Default: false
# Note: Uses fake Redis and mocked Jira client
# Required: No (only for testing)
MOCK_EXTERNAL_SERVICES=false

# Testing environment indicator
# Values: true | false
# Default: false
# Note: Disables certain validations and external calls
# Required: No (only for unit/integration tests)
TESTING=false

# ----------------------------------------------------------------------------
# Observability Configuration
# ----------------------------------------------------------------------------

# Enable Prometheus metrics collection
# Values: true | false
# Default: true
# Required: No
ENABLE_METRICS=true

# Metrics namespace prefix
# Format: Alphanumeric string with underscores
# Default: error_triage
# Required: No
METRICS_NAMESPACE=error_triage

# Enable structured JSON logging
# Values: true | false
# Default: true
# Required: No
ENABLE_JSON_LOGGING=true

# CloudWatch log group name
# Format: /aws/ecs/{service-name}
# Example: /aws/ecs/jiratest-error-triage-prod
# Required: No (automatically set by ECS)
CLOUDWATCH_LOG_GROUP=/aws/ecs/jiratest-error-triage-prod

# ----------------------------------------------------------------------------
# End of Configuration Template
# ----------------------------------------------------------------------------
#
# Validation Checklist:
# [ ] All required variables are set (check comments above)
# [ ] Secrets are loaded from AWS Secrets Manager in production
# [ ] Redis and MongoDB endpoints are correct for environment
# [ ] Jira project key and custom fields exist
# [ ] Webhook secrets match external service configuration
# [ ] Service external URL matches load balancer DNS
# [ ] Configuration file paths are accessible
# [ ] .env file is NOT committed to git (check .gitignore)
#
# For assistance, refer to:
# - docs/configuration.md - Detailed configuration guide
# - docs/deployment.md - Deployment runbook
# - README.md - Quick start guide
#
# ============================================================================

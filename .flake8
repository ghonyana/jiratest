# Flake8 Configuration
# Python code style and quality enforcement for the Error Triage → Jira Upserter service
# This configuration is aligned with Black formatter to prevent conflicts

[flake8]
# Maximum line length - aligned with Black formatter default
max-line-length = 120

# Directories and patterns to exclude from linting
exclude =
    __pycache__,
    .git,
    .venv,
    venv,
    env,
    build,
    dist,
    *.egg-info,
    .pytest_cache,
    .tox,
    .mypy_cache,
    .eggs,
    *.egg

# Error codes to ignore (primarily for Black compatibility)
# E203: Whitespace before ':' - conflicts with Black's formatting
# W503: Line break before binary operator - conflicts with Black
# E501: Line too long - handled by Black formatter
ignore = E203,W503,E501

# Per-file ignores - allow specific violations in certain file types
per-file-ignores =
    # Allow unused imports in __init__.py files (used for package exports)
    __init__.py:F401,F403

# McCabe complexity threshold - flag functions with complexity > 10
max-complexity = 10

# Show source code for each error
show-source = True

# Show the specific error code for each violation
show-pep8 = True

# Count the number of occurrences of each error/warning code
statistics = True
